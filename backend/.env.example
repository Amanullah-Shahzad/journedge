APP_DEBUG=false
DATABASE_URL=postgresql+psycopg://your_db_user:your_db_password@localhost:5432/journedge
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-to-a-random-secret-at-least-32-characters
FRONTEND_ORIGIN=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,https://journaledge.netlify.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://journaledge.netlify.app
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://journaledge.netlify.app
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=storage/uploads
MAX_UPLOAD_BYTES=5242880
ALLOWED_UPLOAD_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif
ALLOWED_UPLOAD_EXTENSIONS=.png,.jpg,.jpeg,.webp,.gif
SMTP_ENABLED=false
SMTP_FROM_EMAIL=noreply@journedge.local
RATE_LIMIT_DEFAULT=100/minute

# Optional S3-compatible storage settings
S3_ENDPOINT_URL=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
